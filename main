print("Калькулятор")
print("Знак сложения = + \n Знак вычитания = - \n Знак умножения = * \n Знак деления = / \n Знак стпени = ^"
number1 = int(input("Введите 1 число: "))
number2 = int(input("Введите 2 число: "))
sign = input("Введите знак действия: ")
if sign == "*":
    composition = number1 * number2
    print(f"Ответ {composition}")
elif sign == "-":
    difference = number1 - number2
    print(f"Ответ {difference}")
elif sign == "+":
    amount = number1 + number2
    print(f"Ответ {amount}")
elif sign == "/":
    if number1 % number2 == 0:
        private = number1 // number2
    elif number2 == 0:
        print(" На ноль делить нельзя")
    else:
        private = number1 / number2
    print(f"Ответ {private}")
elif sign == "^":
    degree = number1 ** number2
    print(f"Ответ {degree}")
else:
    print("Ошибка")
